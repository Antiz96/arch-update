#: src/lib/common.sh:134
#, sh-format
msgid ""
"The ${aur_helper} AUR helper set for AUR packages support in the "
"${name}.conf configuration file is not found\\n"
msgstr ""
"${name}.conf konfigurazio fitxategian AUR paketeetarako ezarritako "
"${aur_helper} AUR laguntzailea ez da aurkitu\\n"

#: src/lib/common.sh:175
#, sh-format
msgid ""
"A privilege elevation command is required (sudo, sudo-rs, doas or run0)\\n"
msgstr ""
"Privilegioak igotzeko komando bat behar da (sudo, sudo-rs, doas edo run0)\\n"

#: src/lib/common.sh:180
#, sh-format
msgid ""
"The ${su_cmd} command set for privilege escalation in the ${name}.conf "
"configuration file is not found\\n"
msgstr ""
"${name}.conf konfigurazio fitxategian privilegioak igotzeko ezarritako "
"${su_cmd} komandoa ez da aurkitu\\n"

#: src/lib/common.sh:192
#, sh-format
msgid ""
"The ${diff_prog} editor set for visualizing / editing differences of pacnew "
"files in the ${name}.conf configuration file is not found\\n"
msgstr ""
"${name}.conf konfigurazio fitxategian pacnew fitxategien arteko aldeak "
"ikusteko edo editatzeko ezarritako ${diff_prog} editorea ez da aurkitu\\n"

#: src/lib/edit-config.sh:9 src/lib/show-config.sh:9
#, sh-format
msgid ""
"No configuration file found\\nYou can generate one with \"${name} --gen-"
"config\""
msgstr ""
"Ez da konfigurazio fitxategirik aurkitu\\nBat sortu dezakezu \"${name} --gen-"
"config\" erabiliz"

#: src/lib/edit-config.sh:13
#, sh-format
msgid ""
"Unable to determine the editor to use\\nThe \"EDITOR\" environment variable "
"is not set and \"nano\" (fallback option) is not installed"
msgstr ""
"Ezin izan da erabili beharreko editorea zehaztu\\n\"EDITOR\" ingurune-"
"aldagaia ez dago ezarrita eta \"nano\" (ordezko aukera) ez dago instalatuta"

#: src/lib/full_upgrade.sh:13
#, sh-format
msgid "There's already a running instance of ${_name}\\n"
msgstr "Dagoeneko ${_name}-(r)en instantzia bat exekutatzen ari da\\n"

