#, sh-format
msgid "Example configuration file not found"
msgstr "Adibidezko konfigurazio fitxategia ez da aurkitu"

#: src/lib/gen-config.sh:25
#, sh-format
msgid ""
"The '${config_file}' configuration file already exists\\nPlease, remove it "
"before generating a new one (or use --force to overwrite it)"
msgstr ""
"'${config_file}' konfigurazio fitxategia badago lehendik\\nMesezez, ezabatu "
"berri bat sortu aurretik (edo erabili --force gainidazteko)"

#: src/lib/gen-config.sh:30
#, sh-format
msgid "The '${config_file}' configuration file has been generated"
msgstr "'${config_file}' konfigurazio fitxategia sortu da"

#: src/lib/help.sh:8
#, sh-format
msgid ""
"An interactive update notifier & applier for Arch Linux that assists you "
"with important pre / post update tasks."
msgstr ""
"Arch Linuxerako eguneraketa-jakinarazle eta aplikatzaile interaktiboa, "
"eguneratze aurreko eta ondorengo zeregin garrantzitsuetan laguntzen dizuna."

#: src/lib/help.sh:10
#, sh-format
msgid "Run ${name} to perform the main 'update' function:"
msgstr "Exekutatu ${name} 'eguneratze' funtzio nagusia abiarazteko:"

#: src/lib/help.sh:11
#, sh-format
msgid ""
"Display the list of packages available for update, then ask for the user's "
"confirmation to proceed with the installation."
msgstr ""
"Eguneratzeko prest dauden paketeen zerrenda erakusten du, eta ondoren "
"erabiltzaileari berrespena eskatzen dio instalazioarekin jarraitzeko."

#: src/lib/help.sh:12
#, sh-format
msgid ""
"Before performing the update, it offers to display the latest Arch Linux "
"news."
msgstr ""
"Eguneraketa egin aurretik, Arch Linuxeko azken berriak ikusteko aukera "
"ematen du."

#: src/lib/help.sh:13
#, sh-format
msgid ""
"Post update, it checks for orphan & unused packages, old cached packages, "
"pacnew & pacsave files, pending kernel update as well as services requiring "
"a post upgrade restart and, if there are, offers to process them."
msgstr ""
"Eguneratu ondoren, pakete umezurtz eta erabili gabeak, cacheko pakete "
"zaharrak, pacnew eta pacsave fitxategiak, zain dauden kernel eguneraketak "
"eta berrabiarazi behar diren zerbitzuak egiaztatzen ditu, eta egonez gero, "
"horiek kudeatzea eskaintzen du."

#: src/lib/help.sh:15
#, sh-format
msgid "Options:"
msgstr "Aukerak:"

#: src/lib/help.sh:16
#, sh-format
msgid ""
"  -c, --check       Check for available updates, change the systray icon and "
"send a desktop notification containing the number of available updates (if "
"there are new available updates compared to the last check)"
msgstr ""
"  -c, --check        Eguneraketa erabilgarriak egiaztatu, sistemako "
"erretiluko ikonoa aldatu eta jakinarazpen bat bidali eguneraketa "
"kopuruarekin (azken egiaztapenetik eguneraketa berriak egonez gero)"

#: src/lib/help.sh:17
#, sh-format
msgid "  -l, --list        Display the list of pending updates"
msgstr "  -l, --list         Zain dauden eguneraketen zerrenda erakutsi"

#: src/lib/help.sh:18
#, sh-format
msgid "  -d, --devel       Include AUR development packages updates"
msgstr "  -d, --devel        Sartu AUReko garapen-paketeen eguneraketak"

#: src/lib/help.sh:19
#, sh-format
msgid ""
"  -n, --news [Num]  Display latest Arch news, you can optionally specify the "
"number of Arch news to display with '--news [Num]' (e.g. '--news 10')"
msgstr ""
"  -n, --news [Zenb]  Arch-en azken berriak erakutsi. Nahi izanez gero, "
"erakutsi beharreko berri kopurua zehaztu dezakezu '--news [Zenb]' erabiliz "
"(adib. '--news 10')"

#: src/lib/help.sh:20
#, sh-format
msgid "  -s, --services    Check for services requiring a post upgrade restart"
msgstr ""
"  -s, --services     Eguneratu ondoren berrabiarazi behar diren zerbitzuak "
"egiaztatu"

#: src/lib/help.sh:21
#, sh-format
msgid "  -D, --debug       Display debug traces"
msgstr "  -D, --debug        Erakutsi arazte-aztarnak (debug)"

#: src/lib/help.sh:22
#, sh-format
msgid ""
"  --gen-config      Generate a default / example '${name}.conf' "
"configuration file, you can optionally pass the '--force' argument to "
"overwrite any existing '${name}.conf' configuration file"
msgstr ""
"  --gen-config      Sortu lehenetsitako/adibidezko '${name}.conf' "
"konfigurazio fitxategia. Nahi izanez gero, '--force' argumentua erabili "
"dezakezu lehendik dagoen '${name}.conf' fitxategia gainidazteko"

#: src/lib/help.sh:23
#, sh-format
msgid ""
"  --show-config     Display the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --show-config      Erakutsi unean erabiltzen ari den '${name}.conf' "
"konfigurazio fitxategia (baldin badago)"

#: src/lib/help.sh:24
#, sh-format
msgid ""
"  --edit-config     Edit the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --edit-config      Editatu unean erabiltzen ari den '${name}.conf' "
"konfigurazio fitxategia (baldin badago)"

#: src/lib/help.sh:25
#, sh-format
msgid ""
"  --tray            Launch the ${_name} systray applet, you can optionally "
"add the '--enable' argument to start it automatically at boot"
msgstr ""
"  --tray             Abiarazi ${_name} sistemako erretiluko applet-a. Nahi "
"izanez gero, '--enable' argumentua gehitu dezakezu abiaraztean automatikoki "
"hasteko"

#: src/lib/help.sh:26
#, sh-format
msgid "  -h, --help        Display this help message and exit"
msgstr "  -h, --help         Laguntza mezu hau erakutsi eta irten"

#: src/lib/help.sh:27
#, sh-format
msgid "  -V, --version     Display version information and exit"
msgstr "  -V, --version      Bertsioaren informazioa erakutsi eta irten"

#: src/lib/help.sh:29
#, sh-format
msgid "For more information, see the ${name}(1) man page."
msgstr "Informazio gehiagorako, ikus ${name}(1) man orrialdea."

#: src/lib/help.sh:30
#, sh-format
msgid ""
"Certain options can be enabled, disabled or modified via the ${name}.conf "
"configuration file, see the ${name}.conf(5) man page."
msgstr ""
"Zenbait aukera gaitu, desgaitu edo aldatu daitezke ${name}.conf konfigurazio "
"fitxategiaren bidez, ikus ${name}.conf(5) man orrialdea."

#: src/lib/invalid_option.sh:7
#, sh-format
msgid ""
"${name}: invalid option -- '${option}'\\nTry '${name} --help' for more "
"information"
msgstr ""
"${name}: aukera baliogabea -- '${option}'\\nProbatu '${name} --help' "
"informazio gehiagorako"

#: src/lib/kernel_reboot.sh:10
#, sh-format
msgid ""
"Reboot required:\\nThere's a pending kernel update on your system requiring "
"a reboot to be applied\\n"
msgstr ""
"Berrabiarazi behar da:\\nZain dagoen kernel eguneraketa bat dago zure "
"sisteman eta berrabiaraztea beharrezkoa da aplikatzeko\\n"

