#: src/lib/full_upgrade.sh:13
#, sh-format
msgid "There's already a running instance of ${_name}\\n"
msgstr "Вече има работеща инстанция на ${_name}\\n"

#: src/lib/gen-config.sh:19
#, sh-format
msgid "Example configuration file not found"
msgstr "Примерният конфигурационен файл не е намерен"

#: src/lib/gen-config.sh:25
#, sh-format
msgid ""
"The '${config_file}' configuration file already exists\\nPlease, remove it "
"before generating a new one (or use --force to overwrite it)"
msgstr ""
"Конфигурационният файл '${config_file}' вече съществува\\nМоля, премахнете "
"го преди да генерирате нов (или използвайте --force за да го презапишете)"

#: src/lib/gen-config.sh:30
#, sh-format
msgid "The '${config_file}' configuration file has been generated"
msgstr "Конфигурационният файл '${config_file}' е генериран"

#: src/lib/help.sh:8
#, sh-format
msgid ""
"An interactive update notifier & applier for Arch Linux that assists you "
"with important pre / post update tasks."
msgstr ""
"Интерактивен нотификатор и инструмент за актуализиране на Arch Linux, който "
"ви помага с важни задачи преди и след актуализация."

#: src/lib/help.sh:10
#, sh-format
msgid "Run ${name} to perform the main 'update' function:"
msgstr "Изпълнете ${name} за да извършите основната функция 'актуализация':"

#: src/lib/help.sh:11
#, sh-format
msgid ""
"Display the list of packages available for update, then ask for the user's "
"confirmation to proceed with the installation."
msgstr ""
"Показва списък с пакети, налични за актуализация, след което пита "
"потребителя за потвърждение преди инсталация."

#: src/lib/help.sh:12
#, sh-format
msgid ""
"Before performing the update, it offers to display the latest Arch Linux "
"news."
msgstr ""
"Преди извършване на актуализацията предлага да покаже последните новини на "
"Arch Linux."

#: src/lib/help.sh:13
#, sh-format
msgid ""
"Post update, it checks for orphan & unused packages, old cached packages, "
"pacnew & pacsave files, pending kernel update as well as services requiring "
"a post upgrade restart and, if there are, offers to process them."
msgstr ""
"След актуализацията проверява за изоставени и неизползвани пакети, стари "
"кеширани пакети, pacnew и pacsave файлове, чакаща актуализация на ядрото, "
"както и услуги, изискващи рестартиране след обновяване, и ако има такива, "
"предлага да ги обработи."

#: src/lib/help.sh:15
#, sh-format
msgid "Options:"
msgstr "Опции:"

#: src/lib/help.sh:16
#, sh-format
msgid ""
"  -c, --check       Check for available updates, change the systray icon and "
"send a desktop notification containing the number of available updates (if "
"there are new available updates compared to the last check)"
msgstr ""
"  -c, --check       Проверява за налични актуализации, променя иконата в "
"системния трей и изпраща настолно известие с броя на наличните актуализации "
"(ако има нови спрямо последната проверка)"

#: src/lib/help.sh:17
#, sh-format
msgid "  -l, --list        Display the list of pending updates"
msgstr "  -l, --list        Показва списък с чакащи актуализации"

#: src/lib/help.sh:18
#, sh-format
msgid "  -d, --devel       Include AUR development packages updates"
msgstr "  -d, --devel       Включва актуализации на развойни AUR пакети"

#: src/lib/help.sh:19
#, sh-format
msgid ""
"  -n, --news [Num]  Display latest Arch news, you can optionally specify the "
"number of Arch news to display with '--news [Num]' (e.g. '--news 10')"
msgstr ""
"  -n, --news [Num]  Показва последните новини на Arch, можете по желание да "
"укажете брой новини за показване с '--news [Num]' (напр. '--news 10')"

#: src/lib/help.sh:20
#, sh-format
msgid "  -s, --services    Check for services requiring a post upgrade restart"
msgstr ""
"  -s, --services    Проверява за услуги, изискващи рестартиране след "
"обновяване"

#: src/lib/help.sh:21
#, sh-format
msgid "  -D, --debug       Display debug traces"
msgstr "  -D, --debug       Показва проследяване за отстраняване на грешки"

#: src/lib/help.sh:22
#, sh-format
msgid ""
"  --gen-config      Generate a default / example '${name}.conf' "
"configuration file, you can optionally pass the '--force' argument to "
"overwrite any existing '${name}.conf' configuration file"
msgstr ""
"  --gen-config      Генерира стандартен/примерен конфигурационен файл "
"'${name}.conf', по желание можете да подадете аргумента '--force' за "
"презаписване на съществуващ файл '${name}.conf'"

#: src/lib/help.sh:23
#, sh-format
msgid ""
"  --show-config     Display the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --show-config     Показва текущо използвания конфигурационен файл "
"'${name}.conf' (ако съществува)"

#: src/lib/help.sh:24
#, sh-format
msgid ""
"  --edit-config     Edit the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --edit-config     Редактира текущо използвания конфигурационен файл "
"'${name}.conf' (ако съществува)"

#: src/lib/help.sh:25
#, sh-format
msgid ""
"  --tray            Launch the ${_name} systray applet, you can optionally "
"add the '--enable' argument to start it automatically at boot"
msgstr ""
"  --tray            Стартира аплета в системния трей ${_name}, по желание "
"можете да добавите аргумента '--enable' за автоматично стартиране при "
"зареждане"

#: src/lib/help.sh:26
#, sh-format
msgid "  -h, --help        Display this help message and exit"
msgstr "  -h, --help        Показва това помощно съобщение и излиза"

#: src/lib/help.sh:27
#, sh-format
msgid "  -V, --version     Display version information and exit"
msgstr "  -V, --version     Показва информация за версията и излиза"

#: src/lib/help.sh:29
#, sh-format
msgid "For more information, see the ${name}(1) man page."
msgstr "За повече информация вижте ръководството ${name}(1)."

#: src/lib/help.sh:30
#, sh-format
msgid ""
"Certain options can be enabled, disabled or modified via the ${name}.conf "
"configuration file, see the ${name}.conf(5) man page."
msgstr ""
"Някои опции могат да бъдат включени, изключени или променени чрез "
"конфигурационния файл ${name}.conf, вижте ръководството ${name}.conf(5)."

#: src/lib/invalid_option.sh:7
#, sh-format
msgid ""
"${name}: invalid option -- '${option}'\\nTry '${name} --help' for more "
"information"
msgstr ""
"${name}: невалидна опция -- '${option}'\\nОпитайте '${name} --help' за "
"повече информация"

#: src/lib/kernel_reboot.sh:10
#, sh-format
msgid ""
"Reboot required:\\nThere's a pending kernel update on your system requiring "
"a reboot to be applied\\n"
msgstr ""
"Необходимо е рестартиране:\\nИма чакаща актуализация на ядрото, която "
"изисква рестартиране за прилагане\\n"

#: src/lib/kernel_reboot.sh:11
#, sh-format
msgid "Would you like to reboot now? [y/N]"
msgstr "Желаете ли да рестартирате сега? [y/N]"

#: src/lib/kernel_reboot.sh:24
#, sh-format
msgid "Rebooting in ${sec}...\\r"
msgstr "Рестартиране след ${sec}...\\r"

#: src/lib/kernel_reboot.sh:30
#, sh-format
msgid ""
"An error has occurred during the reboot process\\nThe reboot has been "
"aborted\\n"
msgstr ""
"Възникна грешка при процеса на рестартиране\\nРестартирането е прекратено\\n"

#: src/lib/kernel_reboot.sh:38
#, sh-format
msgid ""
"The reboot hasn't been performed\\nPlease, consider rebooting to finalize "
"the pending kernel update\\n"
msgstr ""
"Рестартирането не е извършено\\nМоля, обмислете рестартиране за да завършите "
"чакащата актуализация на ядрото\\n"

#: src/lib/kernel_reboot.sh:42
#, sh-format
msgid "No pending kernel update found\\n"
msgstr "Няма намерена чакаща актуализация на ядрото\\n"

