#: src/lib/common.sh:96
#, sh-format
msgid "WARNING"
msgstr "გაფრთხილება"

#: src/lib/common.sh:102
#, sh-format
msgid "ERROR"
msgstr "შეცდომა"

#: src/lib/common.sh:107
#, sh-format
msgid "Press \"enter\" to continue "
msgstr "და გასაგრძელებლად დააჭირეთ ღილაკს 'Enter' "

#: src/lib/common.sh:113
#, sh-format
msgid "Press \"enter\" to quit "
msgstr "გასასვლელად დააჭირეთ ღილაკს \"Enter\" "

#: src/lib/common.sh:134
#, sh-format
msgid ""
"The ${aur_helper} AUR helper set for AUR packages support in the "
"${name}.conf configuration file is not found\\n"
msgstr ""
"AUR-ის დამხმარე ${aur_helper}, დაყენებული AUR პაკეტების მხარდაჭერისთვის "
"კონფიგურაციის ფაილში ${name}.conf აღმოჩენილი არაა\\n"

#: src/lib/common.sh:165
#, sh-format
msgid ""
"A privilege elevation command is required (sudo, sudo-rs, doas or run0)\\n"
msgstr ""
"აუცილებელია პრივილეგიების ამაღლების ბრძანება (sudo, sudo-rs, doas, ან "
"run0)\\n"

#: src/lib/common.sh:170
#, sh-format
msgid ""
"The ${su_cmd} command set for privilege escalation in the ${name}.conf "
"configuration file is not found\\n"
msgstr ""
"ბრძანება ${su_cmd}, დაყენებული პრივილეგიების აწევისთვის კონფიგურაციის ფაილში "
"${name}.conf, აღმოჩენილი არაა\\n"

#: src/lib/common.sh:182
#, sh-format
msgid ""
"The ${diff_prog} editor set for visualizing / editing differences of pacnew "
"files in the ${name}.conf configuration file is not found\\n"
msgstr ""
"რედაქტორი ${diff_prog}, დაყენებული pacnew ფაილების ვიზუალიზაციისთვის / "
"სხვაობების ჩასასწორებლად კონფიგურაციის ფაილში ${name}.conf აღმოჩენილი არაა\\n"

#: src/lib/edit-config.sh:9 src/lib/show-config.sh:9
#, sh-format
msgid ""
"No configuration file found\\nYou can generate one with \"${name} --gen-"
"config\""
msgstr ""
"კონფიგურაციის ფაილი აღმოჩენილი არაა\\nმისი გენერაცია შეგიძლიათ ბრძანებით "
"\"${name} --gen-config\""

#: src/lib/edit-config.sh:13
#, sh-format
msgid ""
"Unable to determine the editor to use\\nThe \"EDITOR\" environment variable "
"is not set and \"nano\" (fallback option) is not installed"
msgstr ""
"გამოსაყენებელი რედაქტორის დადგენა შეუძლებელია\\nგარემოს ცვლადი \"EDITOR\" და "
"\"nano\" (სარეზერვო ვარიანტი) დაყენებული არაა"

#: src/lib/full_upgrade.sh:13
#, sh-format
msgid "There's already a running instance of ${_name}\\n"
msgstr "${_name}-ის გაშვებული ასლი უკვე არსებობს\\n"

#: src/lib/gen-config.sh:19
#, sh-format
msgid "Example configuration file not found"
msgstr "კონფიგურაციის ფაილის მაგალითი ვერ მოიძებნა"

#: src/lib/gen-config.sh:25
#, sh-format
msgid ""
"The '${config_file}' configuration file already exists\\nPlease, remove it "
"before generating a new one (or use --force to overwrite it)"
msgstr ""
"კონფიგურაციის ფაილი '${config_file}' უკვე არსებობს\\nწაშალეთ ის ახლის "
"გენერაციამდე (ან, თუ გნებავთ, თავზე გადააწეროთ, გამოიყენეთ --force)"

#: src/lib/gen-config.sh:30
#, sh-format
msgid "The '${config_file}' configuration file has been generated"
msgstr "დაგენერირდა კონფიგურაციის ფაილი '${config_file}'"

#: src/lib/help.sh:8
#, sh-format
msgid ""
"An interactive update notifier & applier for Arch Linux that assists you "
"with important pre / post update tasks."
msgstr ""
"ინტერაქტიური განახლებების შემხსენებელი და გადამტარებელი Arch Linux-ისთვის, "
"რომელიც გეხმარებათ განახლებამდელ/განახლების შემდგომ ამოცანებში."

#: src/lib/help.sh:10
#, sh-format
msgid "Run ${name} to perform the main 'update' function:"
msgstr "გაუშვით ${name} მთავარი 'update' ფუნქციის შესასრულებლად:"

#: src/lib/help.sh:11
#, sh-format
msgid ""
"Display the list of packages available for update, then ask for the user's "
"confirmation to proceed with the installation."
msgstr ""
"განახლებისთვის ხელმისაწვდომი პაკეტების სიის ჩვენება, შემდეგ კი მომხმარებლის "
"დადასტურების მოთხოვნა დაყენების გასაგრძელებლად."

#: src/lib/help.sh:12
#, sh-format
msgid ""
"Before performing the update, it offers to display the latest Arch Linux "
"news."
msgstr ""
"განახლების შესრულებამდე ის გთავაზობთ Arch Linux-ის უახლესი სიახლეების "
"ჩვენებას."

#: src/lib/help.sh:13
#, sh-format
msgid ""
"Post update, it checks for orphan & unused packages, old cached packages, "
"pacnew & pacsave files, pending kernel update as well as services requiring "
"a post upgrade restart and, if there are, offers to process them."
msgstr ""
"განახლების შემდეგ ის ამოწმებს მიტოვებულ & გამოუყენებელ პაკეტებს, ძველ "
"დაკეშილ პაკეტებს, pacnew & pacsave ფაილებს, რიგში მყოფ ბირთვის განახლებას და "
"სერვისებს, რომლებსაც განახლების შემდეგ გადატვირთვა სჭირდება და თუ ეს "
"აუცილებელია, გთავაზობთ მათ დამუშავებას."

#: src/lib/help.sh:15
#, sh-format
msgid "Options:"
msgstr "მორგება:"

#: src/lib/help.sh:16
#, sh-format
msgid ""
"  -c, --check       Check for available updates, change the systray icon and "
"send a desktop notification containing the number of available updates (if "
"there are new available updates compared to the last check)"
msgstr ""
"  -c, --check       ხელმისაწვდომი განახლებების შემოწმება, სისტემურ საათთან "
"ხატულას შეცვლა და სამუშაო მაგიდისთვის გაფრთხილების გაგზავნა რომელიც "
"ხელმისაწვდომი განახლებების რაოდენობას შეიცავს (თუ არსებობს ხელმისაწვდომი "
"განახლებები ბოლო შემოწმებასთან შედარებით)"

#: src/lib/help.sh:17
#, sh-format
msgid "  -l, --list        Display the list of pending updates"
msgstr "  -l, --list        დარჩენილი განახლებების ჩამონათვალის ჩვენება"

#: src/lib/help.sh:18
#, sh-format
msgid "  -d, --devel       Include AUR development packages updates"
msgstr "  -d, --devel       AUR-ის პროგრამისტის პაკეტის განახლებების ჩათვლა"

#: src/lib/help.sh:19
#, sh-format
msgid ""
"  -n, --news [Num]  Display latest Arch news, you can optionally specify the "
"number of Arch news to display with '--news [Num]' (e.g. '--news 10')"
msgstr ""
"  -n, --news [Num]  Arch-ის სიახლეების ჩვენება. შეგიძლიათ ასევე მიუთითოთ, "
"რამდენი სიახლე გნებავთ პარამეტრით '--news [რიცხვი]' (მაგ: '--news 10')"

#: src/lib/help.sh:20
#, sh-format
msgid "  -s, --services    Check for services requiring a post upgrade restart"
msgstr ""
"  -s, --services    განახლების შემდეგ გადატვირთვის საჭიროების მქონე "
"სერვისების შემოწმება"

#: src/lib/help.sh:21
#, sh-format
msgid "  -D, --debug       Display debug traces"
msgstr "  -D, --debug       გამართვის ინფორმაციის გამოტანა"

#: src/lib/help.sh:22
#, sh-format
msgid ""
"  --gen-config      Generate a default / example '${name}.conf' "
"configuration file, you can optionally pass the '--force' argument to "
"overwrite any existing '${name}.conf' configuration file"
msgstr ""
"  --gen-config      ნაგულისხმევი / მაგალითი '${name}.conf' კონფიგურაციის "
"ფაილის გენერაცია. შეგიძლიათ ასევე გადასცეთ პარამეტრი '--force' რომ არსებულ "
"ფაილს '${name}.conf' თავზე გადაეწეროს"

#: src/lib/help.sh:23
#, sh-format
msgid ""
"  --show-config     Display the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --show-config     ამჟამად გამოყენებული კონფიგურაციის ფაილის '${name}.conf' "
"გამოტანა (თუ არსებობს)"

#: src/lib/help.sh:24
#, sh-format
msgid ""
"  --edit-config     Edit the '${name}.conf' configuration file currently "
"used (if it exists)"
msgstr ""
"  --edit-config     ამჟამად გამოყენებული კონფიგურაციის ფაილის '${name}.conf' "
"ჩასწორება (თუ არსებობს)"

#: src/lib/help.sh:25
#, sh-format
msgid ""
"  --tray            Launch the ${_name} systray applet, you can optionally "
"add the '--enable' argument to start it automatically at boot"
msgstr ""
"  --tray             ${_name}-ის აპლეტის გაშვება სისტემურ საათთან. ასევე "
"შეგიძლიათ, დაამატოთ არგუმენტი '--enable', რომ ის ჩატვირთვისას გაეშვას"

#: src/lib/help.sh:26
#, sh-format
msgid "  -h, --help        Display this help message and exit"
msgstr "  -h, --help        ამ დახმარების შეტყობინების გამოტანა და გასვლა"

#: src/lib/help.sh:27
#, sh-format
msgid "  -V, --version     Display version information and exit"
msgstr "  -V, --version     ვერსიის ინფორმაციის გამოტანა და გასვლა"

#: src/lib/help.sh:29
#, sh-format
msgid "For more information, see the ${name}(1) man page."
msgstr "მეტი ინფორმაციისთვის იხილეთ ${name}(1)."

#: src/lib/help.sh:30
#, sh-format
msgid ""
"Certain options can be enabled, disabled or modified via the ${name}.conf "
"configuration file, see the ${name}.conf(5) man page."
msgstr ""
"ზოგიერთი პარამეტრი შეგიძლიათ ჩართოთ, გამორთოთ, ან შეცვალოთ კონფიგურაციის "
"ფაილში ${name}.conf დეტალებისთვის იხილეთ დოკუმენტაცია ${name}.conf(5)."

#: src/lib/invalid_option.sh:7
#, sh-format
msgid ""
"${name}: invalid option -- '${option}'\\nTry '${name} --help' for more "
"information"
msgstr ""
"${name}: არასწორი პარამეტრი -- '${option}'\\nმეტი ინფორმაციისთვის სცადეთ "
"'${name} --help'"

#: src/lib/kernel_reboot.sh:10
#, sh-format
msgid ""
"Reboot required:\\nThere's a pending kernel update on your system requiring "
"a reboot to be applied\\n"
msgstr ""
"საჭიროა გადატვირთვა:\\nრიგშია ბირთვის განახლება, რომელსაც გადასატარებლად "
"სისტემის გადატვირთვა სჭირდება\\n"

#: src/lib/kernel_reboot.sh:11
#, sh-format
msgid "Would you like to reboot now? [y/N]"
msgstr "გნებავთ გადატვირთვა ახლავე? [y/N]"

#: src/lib/kernel_reboot.sh:15 src/lib/list_packages.sh:113
#: src/lib/orphan_packages.sh:25 src/lib/orphan_packages.sh:59
#: src/lib/packages_cache.sh:30 src/lib/pacnew_files.sh:21
#, sh-format
msgid "Y"
msgstr "Y"

#: src/lib/kernel_reboot.sh:15 src/lib/list_packages.sh:113
#: src/lib/orphan_packages.sh:25 src/lib/orphan_packages.sh:59
#: src/lib/packages_cache.sh:30 src/lib/pacnew_files.sh:21
#, sh-format
msgid "y"
msgstr "y"

#: src/lib/kernel_reboot.sh:24
#, sh-format
msgid "Rebooting in ${sec}...\\r"
msgstr "გადატვირთვა ${sec} წამში...\\r"

#: src/lib/kernel_reboot.sh:30
#, sh-format
msgid ""
"An error has occurred during the reboot process\\nThe reboot has been "
"aborted\\n"
msgstr "გადატვირთვის პროცესისას აღმოჩენილია შეცდომა\\nგადატვირთვა შეწყდა\\n"

#: src/lib/kernel_reboot.sh:38
#, sh-format
msgid ""
"The reboot hasn't been performed\\nPlease, consider rebooting to finalize "
"the pending kernel update\\n"
msgstr ""
"გადატვირთვა არ მომხდარა\\nიფიქრეთ გადატვირთვამდე, რომ ბირთვის განახლება "
"დასრულდეს\\n"

#: src/lib/kernel_reboot.sh:42
#, sh-format
msgid "No pending kernel update found\\n"
msgstr "რიგში მყოფი ბირთვის განახლება აღმოჩენილი არაა\\n"

#: src/lib/list_news.sh:7
#, sh-format
msgid "Looking for recent Arch News..."
msgstr "Arch-ის ახალი ამბების ძებნა..."

#: src/lib/list_news.sh:13
#, sh-format
msgid ""
"Unable to retrieve recent Arch News (HTTP error response or request timeout)"
"\\nPlease, look for any recent news at https://archlinux.org before updating "
"your system"
msgstr ""
"Arch-ის სიახლეების მიღება შეუძლებელია (HTTP შეცდომა, ან მოთხოვნის მოლოდინის "
"ვადა ამოიწურა)\\nსისტემის განახლებამდე სიახლეები საიტზე https://archlinux.org"

#: src/lib/list_news.sh:23
#, sh-format
msgid "No recent Arch News found"
msgstr "Arch-ის ახალი ამბები აღმოჩენილი არაა"

#: src/lib/list_news.sh:37
#, sh-format
msgid "Arch News:"
msgstr "Arch-ის სიახლეები:"

#: src/lib/list_news.sh:42
#, sh-format
msgid "[NEW]"
msgstr "[ახალი]"

#: src/lib/list_news.sh:54
#, sh-format
msgid ""
"Select the news to read (e.g. 1 3 5), select 0 to read them all or press "
"\"enter\" to quit:"
msgstr ""
"აირჩიეთ სიახლეები წასაკითხად (მაგ: 1 3 5). აირჩიეთ 0 ყველას წასაკითხად, ან "
"დააჭირეთ ღილაკს 'Enter' გასასვლელად:"

#: src/lib/list_news.sh:56
#, sh-format
msgid ""
"Select the news to read (e.g. 1 3 5), select 0 to read them all or press "
"\"enter\" to proceed with update:"
msgstr ""
"აირჩიეთ სიახლეები წასაკითხად (მაგ: 1 3 5). აირჩიეთ 0 ყველას წასაკითხად, ან "
"დააჭირეთ ღილაკს 'Enter' განახლების დასაწყებად:"

#: src/lib/list_news.sh:80
#, sh-format
msgid ""
"Unable to retrieve the selected Arch News (HTTP error response or request "
"timeout)\\nPlease, read the selected Arch News at ${news_url} before "
"updating your system"
msgstr ""
"მონიშნული Arch-ის სიახლეების მიღება შეუძლებელია (HTTP შეცდომა, ან მოთხოვნის "
"მოლოდინის ვადა ამოიწურა\\nწაიკთხეთ Arch-ის სიახლე ბმულზე ${news_url} "
"სისტემის განახლებამდე"

#: src/lib/list_news.sh:85
#, sh-format
msgid "Title:"
msgstr "სათაური:"

#: src/lib/list_news.sh:86
#, sh-format
msgid "Author:"
msgstr "ავტორი:"

#: src/lib/list_news.sh:87
#, sh-format
msgid "Publication date:"
msgstr "გამოქვეყნების თარიღი:"

#: src/lib/list_news.sh:88
#, sh-format
msgid "URL:"
msgstr "URL:"

#: src/lib/list_packages.sh:7
#, sh-format
msgid "Looking for updates...\\n"
msgstr "განახლებების ძებნა...\\n"

#: src/lib/list_packages.sh:77
#, sh-format
msgid "Packages:"
msgstr "პაკეტები:"

#: src/lib/list_packages.sh:84
#, sh-format
msgid "AUR Packages:"
msgstr "AUR პაკეტები:"

#: src/lib/list_packages.sh:91
#, sh-format
msgid "Flatpak Packages:"
msgstr "Flatpak პაკეტები:"

#: src/lib/list_packages.sh:101
#, sh-format
msgid "No update available\\n"
msgstr "განახლებები ხელმისაწვდომი არაა\\n"

#: src/lib/list_packages.sh:109
#, sh-format
msgid "Proceed with update? [Y/n]"
msgstr "გაგრძელდეს განახლება? [Y/n]"

